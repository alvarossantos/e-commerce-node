<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0 h3"><i class="fas fa-info-circle text-primary me-2" aria-hidden="true"></i> Detalhes do Produto</h1>
        <a href="/admin/produtos" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fas fa-arrow-left me-2" aria-hidden="true"></i> Voltar à Listagem
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-4 bg-light d-flex align-items-center justify-content-center p-4 border-end">
                <img src="<%= produto.url_imagem ? produto.url_imagem : '/img/produtos/placeholder.png' %>" class="img-fluid rounded shadow-sm" style="max-height: 320px; object-fit: contain;" alt="Imagem de <%= produto.nome %>">
            </div>
            
            <div class="col-md-8">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <span class="badge bg-primary px-3 py-2 rounded-pill mb-2"><%= produto.categoria %></span>
                            <h2 class="fw-bold mb-1"><%= produto.nome %></h2>
                            <p class="text-muted mb-0">SKU: <strong class="text-dark"><%= produto.sku %></strong></p>
                        </div>
                        <h3 class="fw-bold text-primary">R$ <%= parseFloat(produto.preco).toFixed(2) %></h3>
                    </div>

                    <hr class="my-4 text-muted">

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="text-muted small fw-bold text-uppercase mb-2"><i class="fas fa-warehouse me-1" aria-hidden="true"></i> Controle de Inventário</h6>
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2">Estoque Atual: 
                                    <span class="fw-bold <%= (estoque && estoque.quantidade <= estoque.estoque_minimo) ? 'text-danger' : 'text-success' %>">
                                        <%= estoque ? estoque.quantidade : 0 %> unidades
                                    </span>
                                </li>
                                <li>Mínimo para Alerta: <span class="fw-bold text-muted"><%= estoque ? estoque.estoque_minimo : 5 %> unidades</span></li>
                            </ul>
                        </div>
                        
                        <div class="col-md-6">
                            <h6 class="text-muted small fw-bold text-uppercase mb-2"><i class="fas fa-barcode me-1" aria-hidden="true"></i> Identificação Comercial</h6>
                            <p class="mb-0">Código de Barras (EAN):<br><strong class="text-dark"><%= produto.codigo_barras || 'Não registrado' %></strong></p>
                        </div>

                        <div class="col-12">
                            <h6 class="text-muted small fw-bold text-uppercase mb-2"><i class="fas fa-align-left me-1" aria-hidden="true"></i> Descrição do Produto</h6>
                            <p class="text-secondary bg-light p-3 rounded-3 mb-0 text-wrap text-break" style="white-space: pre-line;"><%= produto.descricao %></p>
                        </div>
                    </div>

                    <hr class="my-4 text-muted">

                    <div class="d-flex gap-2">
                        <a href="/admin/produtos/<%= produto.id %>/editar" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                            <i class="fas fa-edit me-2" aria-hidden="true"></i> Editar Produto
                        </a>
                        
                        <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalExcluirDetalhe">
                            <i class="fas fa-trash me-2" aria-hidden="true"></i> Excluir Produto
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalExcluirDetalhe" tabindex="-1" aria-labelledby="modalExcluirDetalheLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-start">
            <div class="modal-header border-bottom-0 pb-0 mt-2">
                <h5 class="modal-title fw-bold text-danger" id="modalExcluirDetalheLabel">
                    <i class="fas fa-exclamation-circle me-2" aria-hidden="true"></i> Confirmar Exclusão
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body py-4">
                <p class="mb-0">Tem certeza que deseja excluir o produto <strong><%= produto.nome %></strong> permanentemente?</p>
                <p class="text-muted small mt-2 mb-0">O sistema verificará automaticamente se o produto possui vendas, estoque ou está em carrinhos de compra antes de permitir a exclusão.</p>
            </div>
            <div class="modal-footer border-top-0 pt-0 mb-2">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <form action="/admin/produtos/<%= produto.id %>?_method=DELETE" method="POST" class="m-0 p-0">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">Sim, Excluir</button>
                </form>
            </div>
        </div>
    </div>
</div>
