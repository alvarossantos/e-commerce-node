<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card border-0 shadow rounded-4 p-4 mt-4">
                <div class="text-center mb-4">
                    <i class="fas fa-user-circle fa-4x text-primary mb-3" aria-hidden="true"></i>
                    <h1 class="fw-bold h3">Bem-vindo de volta!</h1>
                    <p class="text-muted small">Faça login para aceder à sua conta.</p>
                </div>

                <% if (typeof erro !== 'undefined' && erro) { %>
                    <div class="alert alert-danger small py-2 rounded-3 text-center d-flex justify-content-between align-items-center" role="alert"><%= erro %><button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button></div>
                <% } %>
                <% if (typeof sucesso !== 'undefined' && sucesso) { %>
                    <div class="alert alert-success small py-2 rounded-3 text-center d-flex justify-content-between align-items-center" role="alert"><%= sucesso %><button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button></div>
                <% } %>

                <form action="/login" method="POST" novalidate>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label for="login-email" class="form-label fw-bold text-muted small">E-mail</label>
                        <input type="email" id="login-email" name="email" class="form-control rounded-pill px-4" required placeholder="seu@email.com" autocomplete="email">
                    </div>
                    <div class="mb-4">
                        <label for="login-senha" class="form-label fw-bold text-muted small">Senha</label>
                        <input type="password" id="login-senha" name="senha" class="form-control rounded-pill px-4" required placeholder="••••••••" autocomplete="current-password">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">Entrar na Conta</button>
                </form>
                
                <div class="text-center mt-4 pt-3 border-top">
                    <span class="text-muted small">Ainda não tem conta?</span>
                    <a href="/cadastro" class="text-decoration-none fw-bold ms-1">Criar conta grátis</a>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    setTimeout(() => {
        document.querySelectorAll('#conteudo-principal .alert[data-bs-dismiss="alert"]').forEach(el => {
            bootstrap.Alert.getOrCreateInstance(el).close();
        });
    }, 5000);
</script>
