<div class="container py-5 font-custom">

    <% if (erro) { %> <div class="alert alert-danger rounded-4 shadow-sm mb-4" role="alert"><%= erro %></div> <% } %>
    <% if (sucesso) { %> <div class="alert alert-success rounded-4 shadow-sm mb-4" role="alert"><%= sucesso %></div> <% } %>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">

                <div class="text-center mb-4">
                    <img src="<%= usuario.url_foto ? usuario.url_foto : '/img/usuarios/default.png' %>" class="rounded-circle border shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" alt="Foto de perfil de <%= usuario.nome %>">

                    <form action="/perfil/foto" method="POST" enctype="multipart/form-data" class="mt-3 px-3">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="mb-2">
                            <label for="foto-upload" class="form-label small fw-bold text-muted w-100 text-start">Fazer Upload de Foto</label>
                            <input class="form-control form-control-sm" type="file" id="foto-upload" name="foto_upload" accept="image/*">
                        </div>

                        <div class="d-flex align-items-center mb-2">
                            <hr class="flex-grow-1 text-muted">
                            <span class="px-2 small text-muted">OU</span>
                            <hr class="flex-grow-1 text-muted">
                        </div>

                        <div class="mb-3">
                            <label for="foto-url" class="form-label small fw-bold text-muted w-100 text-start">Usar link da internet</label>
                            <input type="url" id="foto-url" name="url_foto" class="form-control form-control-sm" placeholder="https://link.com/foto.jpg">
                        </div>

                        <button class="btn btn-primary btn-sm w-100 fw-bold rounded-pill shadow-sm" type="submit">
                            <i class="fas fa-camera me-1" aria-hidden="true"></i> Atualizar Avatar
                        </button>
                    </form>

                    <h2 class="fw-bold mb-0 mt-3 h4"><%= usuario.nome %></h2>
                    <span class="badge bg-light text-muted border mt-2"><%= usuario.email %></span>
                </div>

                <hr class="text-muted mb-4">

                <form action="/perfil/dados" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label for="perfil-nome" class="form-label small fw-bold text-muted">Nome Completo</label>
                        <input type="text" id="perfil-nome" name="nome" class="form-control rounded-pill px-3" value="<%= usuario.nome %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="perfil-telefone" class="form-label small fw-bold text-muted">Telefone de Contato</label>
                        <input type="text" id="perfil-telefone" name="telefone" class="form-control rounded-pill px-3" value="<%= usuario.telefone || '' %>" placeholder="(11) 99999-9999">
                    </div>
                    <div class="mb-4">
                        <label for="perfil-senha" class="form-label small fw-bold text-muted">Nova Senha <small class="text-muted">(Deixe em branco para manter a atual)</small></label>
                        <input type="password" id="perfil-senha" name="senha" class="form-control rounded-pill px-3" placeholder="••••••••" autocomplete="new-password">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">Salvar Dados Cadastrais</button>
                </form>

            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0 h5"><i class="fas fa-map-marked-alt text-primary me-2" aria-hidden="true"></i>Meus Endereços de Entrega</h2>
                    <a href="/perfil/endereco/novo" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold">
                        <i class="fas fa-plus me-1" aria-hidden="true"></i> Novo Endereço
                    </a>
                </div>

                <div class="row g-3">
                    <% if (enderecos.length > 0) { %>
                        <% for (let end of enderecos) { %>
                            <div class="col-12">
                                <div class="p-3 bg-light rounded-4 border d-flex justify-content-between align-items-center">
                                    <div>
                                        <p class="fw-bold mb-1"><%= end.logradouro %>, Nº <%= end.numero %></p>
                                        <span class="text-muted small">
                                            <%= end.bairro %> — <%= end.cidade %>/<%= end.estado %> <br>
                                            CEP: <%= end.cep %> <%= end.complemento ? ' | ' + end.complemento : '' %>
                                        </span>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a href="/perfil/endereco/<%= end.id %>/editar" class="btn btn-sm btn-light border rounded-circle" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;" aria-label="Editar endereço"><i class="fas fa-edit text-primary" aria-hidden="true"></i></a>

                                        <form action="/perfil/endereco/<%= end.id %>?_method=DELETE" method="POST" class="m-0 p-0">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn btn-sm btn-light border rounded-circle" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;" onsubmit="return confirm('Excluir este endereço?')" aria-label="Excluir endereço"><i class="fas fa-trash text-danger" aria-hidden="true"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="fas fa-home fa-3x text-muted mb-3" aria-hidden="true"></i>
                            <h6 class="fw-bold text-muted">Nenhum endereço cadastrado.</h6>
                            <p class="text-muted small">Cadastre um endereço para acelerar suas compras futuras!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
