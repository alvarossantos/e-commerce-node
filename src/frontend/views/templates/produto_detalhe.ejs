<div class="container py-5 font-loja">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Início</a></li>
            <li class="breadcrumb-item"><a href="/?categoria=<%= produto.categoria %>" class="text-decoration-none text-muted"><%= produto.categoria %></a></li>
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page"><%= produto.nome %></li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden p-4 bg-white mb-5">
        <div class="row g-5">
            <div class="col-md-6 d-flex align-items-center justify-content-center bg-light rounded-4 p-4" style="min-height: 400px;">
                <img src="<%= produto.url_imagem ? produto.url_imagem : '/img/produtos/placeholder.png' %>" class="img-fluid rounded-3" style="max-height: 420px; object-fit: contain;" alt="Imagem de <%= produto.nome %>">
            </div>

            <div class="col-md-6 d-flex flex-column justify-content-between">
                <div>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill mb-3 fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <%= produto.categoria %>
                    </span>

                    <h1 class="fw-bold text-dark mb-2 h2"><%= produto.nome %></h1>

                    <%
                        const media = estatisticas.media || 0;
                        const total = estatisticas.total || 0;
                        const estrelasCheias = Math.floor(media);
                        const temMeiaEstrela = (media - estrelasCheias) >= 0.5;
                        const estrelasVazias = 5 - estrelasCheias - (temMeiaEstrela ? 1 : 0);
                    %>
                    <div class="d-flex align-items-center mb-3 gap-2" aria-label="Nota: <%= media > 0 ? media.toFixed(1) : 'Novo' %> de 5 estrelas">
                        <div class="text-warning" aria-hidden="true">
                            <% for(let i=0; i < estrelasCheias; i++) { %><i class="fas fa-star"></i><% } %>
                            <% if(temMeiaEstrela) { %><i class="fas fa-star-half-alt"></i><% } %>
                            <% for(let i=0; i < estrelasVazias; i++) { %><i class="far fa-star"></i><% } %>
                        </div>
                        <span class="fw-bold text-dark fs-6"><%= media > 0 ? media.toFixed(1) : 'Novo' %></span>
                        <a href="#area-avaliacoes" class="text-muted small text-decoration-none hover-primary transition-hover-sm">
                            (<%= total %> <%= total === 1 ? 'avaliação' : 'avaliações' %>)
                        </a>
                    </div>

                    <p class="text-muted small mb-3">Modelo/SKU: <%= produto.sku %></p>

                    <% if (estoque && estoque.quantidade > 0) { %>
                        <div class="mb-4 d-flex align-items-center gap-1">
                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1.5 x-small fw-bold">
                                <i class="fas fa-check-circle me-1" aria-hidden="true"></i> Em estoque (Disponível)
                            </span>
                        </div>
                    <% } else { %>
                        <div class="mb-4 d-flex align-items-center gap-1">
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-1.5 x-small fw-bold">
                                <i class="fas fa-times-circle me-1" aria-hidden="true"></i> Esgotado (Indisponível)
                            </span>
                        </div>
                    <% } %>

                    <div class="bg-light p-3 rounded-4 mb-4">
                        <span class="text-muted d-block small mb-1">Preço à vista no PIX ou Boleto</span>
                        <h2 class="text-primary fw-bold mb-1 font-loja">R$ <%= parseFloat(produto.preco).toFixed(2) %></h2>
                        <span class="text-muted x-small">Ou em até 10x sem juros nos cartões</span>
                    </div>

                    <div class="mb-4">
                        <h3 class="fw-bold text-dark mb-2 h6"><i class="fas fa-info-circle me-1 text-muted" aria-hidden="true"></i> Informações do Produto</h3>
                        <p class="text-secondary small lh-base mb-0"><%= produto.descricao %></p>
                    </div>
                </div>

                <form action="/carrinho/adicionar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="produto_id" value="<%= produto.id %>">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width: 100px;">
                            <label for="quantidade-produto" class="form-label text-muted small mb-1">Quantidade</label>
                            <input type="number" id="quantidade-produto" name="quantidade" class="form-control text-center rounded-pill fw-bold" value="1" min="1" max="<%= estoque ? estoque.quantidade : 1 %>" required>
                        </div>
                        <div class="flex-grow-1 pt-4">
                            <% if (estoque && estoque.quantidade > 0) { %>
                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-2.5 shadow-sm btn-comprar transition-hover-sm">
                                    <i class="fas fa-shopping-bag me-2" aria-hidden="true"></i> Adicionar ao Carrinho
                                </button>
                            <% } else { %>
                                <button type="button" class="btn btn-secondary btn-lg w-100 rounded-pill fw-bold py-2.5" disabled>
                                    Avisar quando chegar
                                </button>
                            <% } %>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <section id="area-avaliacoes" class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4 pt-5 mt-n5" aria-labelledby="titulo-avaliacoes">
        <h2 id="titulo-avaliacoes" class="fw-bold text-dark mb-4 h4 d-flex align-items-center gap-2">
            <i class="fas fa-comments text-muted" aria-hidden="true"></i> Avaliações dos Clientes
        </h2>
        <hr class="text-muted opacity-25 mb-4">

        <% if (typeof usuarioLogado !== 'undefined' && usuarioLogado) { %>
            <div class="bg-light rounded-4 p-4 mb-5">
                <h3 class="fw-bold text-dark mb-3 h5">Deixe a sua opinião</h3>
                <form action="/produtos/<%= produto.id %>/avaliar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="row">
                        <div class="col-md-4 col-lg-3 mb-3">
                            <label for="nota-avaliacao" class="form-label text-muted small fw-bold">Sua Nota</label>
                            <select id="nota-avaliacao" name="nota" class="form-select border-0 shadow-sm rounded-3" required>
                                <option value="5" selected>⭐⭐⭐⭐⭐ (5/5)</option>
                                <option value="4">⭐⭐⭐⭐ (4/5)</option>
                                <option value="3">⭐⭐⭐ (3/5)</option>
                                <option value="2">⭐⭐ (2/5)</option>
                                <option value="1">⭐ (1/5)</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="comentario-avaliacao" class="form-label text-muted small fw-bold">Comentário</label>
                        <textarea id="comentario-avaliacao" name="comentario" class="form-control border-0 shadow-sm rounded-3 p-3" rows="3" required placeholder="O que achou deste produto? Compartilhe a sua experiência de uso..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm btn-comprar">
                        Enviar Avaliação
                    </button>
                </form>
            </div>
        <% } else { %>
            <div class="alert alert-light border rounded-4 text-center py-4 mb-5 shadow-sm">
                <i class="fa-solid fa-lock text-muted mb-2 fs-4" aria-hidden="true"></i>
                <p class="mb-1 text-secondary">Apenas clientes autenticados podem avaliar os produtos.</p>
                <a href="/login" class="text-decoration-none fw-bold text-primary">Faça login ou crie uma conta aqui ➔</a>
            </div>
        <% } %>

        <h3 class="fw-bold text-dark mb-4 h5">Últimos Comentários</h3>

        <% if (typeof avaliacoes !== 'undefined' && avaliacoes.length > 0) { %>
            <div class="row">
                <% avaliacoes.forEach(avaliacao => { %>
                    <div class="col-md-6 mb-4">
                        <div class="border rounded-4 p-3 h-100 bg-light-subtle shadow-xs">
                            <div class="d-flex align-items-center mb-3">
                                <img src="<%= avaliacao.url_foto || '/img/usuarios/default.png' %>" class="rounded-circle me-3 bg-white" style="width: 45px; height: 45px; object-fit: cover; padding: 2px; border: 1px solid #dee2e6;" alt="Foto de <%= avaliacao.nome %>">
                                <div>
                                    <h4 class="mb-0 fw-bold text-dark h6"><%= avaliacao.nome %></h4>
                                    <div class="text-warning small mt-1" aria-label="Nota: <%= avaliacao.nota %> de 5">
                                        <% for(let i = 0; i < avaliacao.nota; i++) { %>★<% } %><% for(let i = avaliacao.nota; i < 5; i++) { %>☆<% } %>
                                    </div>
                                </div>
                            </div>
                            <p class="mb-0 text-secondary small lh-base fst-italic">"<%= avaliacao.comentario %>"</p>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-4 text-muted border border-dashed rounded-4">
                <i class="far fa-comment-dots fs-3 mb-2 opacity-50" aria-hidden="true"></i>
                <p class="mb-0 small fst-italic">Este produto ainda não possui feedbacks. Seja o primeiro a deixar a sua opinião!</p>
            </div>
        <% } %>
    </section>
</div>
