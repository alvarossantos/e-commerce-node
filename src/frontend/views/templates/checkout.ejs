<div class="container py-5 font-custom">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0 h3"><i class="fas fa-lock text-success me-2" aria-hidden="true"></i>Finalizar Compra</h1>
        <a href="/carrinho" class="btn btn-outline-secondary rounded-pill px-4"><i class="fas fa-arrow-left me-2" aria-hidden="true"></i> Voltar ao Carrinho</a>
    </div>

    <form action="/pedidos/processar" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="row g-4">
            
            <div class="col-lg-8">
                
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
                    <h2 class="fw-bold mb-3 h5"><i class="fas fa-map-marker-alt text-primary me-2" aria-hidden="true"></i> Endereço de Entrega</h2>
                    
                    <% if (enderecos && enderecos.length > 0) { %>
                        <div class="row g-3 mb-3" role="radiogroup" aria-label="Selecionar endereço de entrega">
                            <% for(let i=0; i<enderecos.length; i++) { let end = enderecos[i]; %>
                                <div class="col-md-6">
                                    <div class="form-check border p-3 rounded-4 h-100" style="cursor: pointer;" onclick="document.getElementById('end_<%= end.id %>').checked = true;">
                                        <input class="form-check-input mt-1" type="radio" name="endereco_id" id="end_<%= end.id %>" value="<%= end.id %>" <%= i === 0 ? 'checked' : '' %> required>
                                        <label class="form-check-label w-100 ms-2" for="end_<%= end.id %>">
                                            <div class="d-flex justify-content-between">
                                                <strong class="text-dark">Endereço <%= i+1 %></strong>
                                                <% if (end.principal) { %><span class="badge bg-primary-subtle text-primary">Principal</span><% } %>
                                            </div>
                                            <div class="small text-muted mt-1">
                                                <%= end.logradouro %>, <%= end.numero %> <br>
                                                <%= end.bairro %> - <%= end.cidade %>/<%= end.estado %> <br>
                                                CEP: <%= end.cep %>
                                            </div>
                                        </label>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill fw-bold px-3" data-bs-toggle="modal" data-bs-target="#modalEndereco">
                            <i class="fas fa-plus me-1" aria-hidden="true"></i> Adicionar Outro Endereço
                        </button>
                    <% } else { %>
                        <div class="alert alert-warning rounded-3 border-0 d-flex align-items-center mb-3" role="alert">
                            <i class="fas fa-exclamation-triangle fa-2x me-3" aria-hidden="true"></i>
                            <div>Você ainda não possui nenhum endereço de entrega registado.</div>
                        </div>
                        <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalEndereco">
                            Registar Novo Endereço
                        </button>
                        <input type="hidden" name="endereco_id" required>
                    <% } %>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <h2 class="fw-bold mb-3 h5"><i class="fas fa-wallet text-primary me-2" aria-hidden="true"></i> Forma de Pagamento</h2>
                    
                    <div class="form-check border p-3 rounded-4 mb-3 d-flex align-items-center" style="cursor: pointer;" onclick="document.getElementById('pagPix').checked = true;">
                        <input class="form-check-input fs-5 mt-0 me-3" type="radio" name="metodo_pagamento" id="pagPix" value="pix" checked>
                        <label class="form-check-label w-100 d-flex align-items-center" for="pagPix">
                            <i class="fab fa-pix fs-2 text-success me-3" aria-hidden="true"></i>
                            <div>
                                <span class="d-block fw-bold text-dark">PIX (Aprovação Imediata)</span>
                                <span class="text-muted small">O código QR será gerado na próxima etapa.</span>
                            </div>
                        </label>
                    </div>

                    <div class="form-check border p-3 rounded-4 d-flex align-items-center" style="cursor: pointer;" onclick="document.getElementById('pagCartao').checked = true;">
                        <input class="form-check-input fs-5 mt-0 me-3" type="radio" name="metodo_pagamento" id="pagCartao" value="cartao">
                        <label class="form-check-label w-100 d-flex align-items-center" for="pagCartao">
                            <i class="fas fa-credit-card fs-2 text-primary me-3" aria-hidden="true"></i>
                            <div>
                                <span class="d-block fw-bold text-dark">Cartão de Crédito</span>
                                <span class="text-muted small">Emulador de pagamento para testes.</span>
                            </div>
                        </label>
                    </div>
                </div>

            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-light position-sticky" style="top: 100px;">
                    <h2 class="fw-bold mb-4 h5">Resumo do Pedido</h2>
                    
                    <div class="mb-4" style="max-height: 300px; overflow-y: auto;" aria-label="Itens do pedido">
                        <% for(let item of itens) { %>
                            <div class="d-flex align-items-center mb-3">
                                <img src="<%= item.url_imagem || '/img/produtos/placeholder.png' %>" class="rounded border bg-white me-2" style="width: 50px; height: 50px; object-fit: cover;" alt="Imagem de <%= item.nome %>">
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 small fw-bold text-truncate" style="max-width: 150px;"><%= item.nome %></h6>
                                    <small class="text-muted"><%= item.quantidade %>x R$ <%= parseFloat(item.preco).toFixed(2) %></small>
                                </div>
                                <div class="fw-bold text-success small">
                                    R$ <%= (parseFloat(item.preco) * item.quantidade).toFixed(2) %>
                                </div>
                                <input type="hidden" name="produtos[]" value="<%= item.produto_id %>">
                            </div>
                        <% } %>
                    </div>

                    <hr>
                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>Subtotal</span>
                        <span>R$ <%= total.toFixed(2) %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Frete</span>
                        <span class="badge bg-success text-white">Grátis</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Total a Pagar</span>
                        <span class="fw-bold fs-4 text-primary">R$ <%= total.toFixed(2) %></span>
                        <input type="hidden" name="valor_total" value="<%= total %>">
                    </div>

                    <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-3 shadow-sm text-uppercase">
                        Confirmar Pagamento <i class="fas fa-check-circle ms-2" aria-hidden="true"></i>
                    </button>
                    <div class="text-center mt-3 text-muted" style="font-size: 0.75rem;">
                        <i class="fas fa-shield-alt me-1" aria-hidden="true"></i> Ambiente Seguro e Criptografado
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="modalEndereco" tabindex="-1" aria-labelledby="modalEnderecoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold" id="modalEnderecoLabel"><i class="fas fa-home text-primary me-2" aria-hidden="true"></i> Novo Endereço</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body pt-0">
                <form action="/enderecos/adicionar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="row g-3">
                        <div class="col-8">
                            <label for="modal-cep" class="form-label small fw-bold">CEP</label>
                            <input type="text" id="modal-cep" name="cep" class="form-control" required placeholder="Ex: 37980-000" inputmode="numeric">
                        </div>
                        <div class="col-8">
                            <label for="modal-logradouro" class="form-label small fw-bold">Rua / Logradouro</label>
                            <input type="text" id="modal-logradouro" name="logradouro" class="form-control" required>
                        </div>
                        <div class="col-4">
                            <label for="modal-numero" class="form-label small fw-bold">Número</label>
                            <input type="text" id="modal-numero" name="numero" class="form-control" required inputmode="numeric">
                        </div>
                        <div class="col-12">
                            <label for="modal-complemento" class="form-label small fw-bold text-muted">Complemento (Opcional)</label>
                            <input type="text" id="modal-complemento" name="complemento" class="form-control" placeholder="Apto, Casa dos fundos...">
                        </div>
                        <div class="col-5">
                            <label for="modal-bairro" class="form-label small fw-bold">Bairro</label>
                            <input type="text" id="modal-bairro" name="bairro" class="form-control" required>
                        </div>
                        <div class="col-4">
                            <label for="modal-cidade" class="form-label small fw-bold">Cidade</label>
                            <input type="text" id="modal-cidade" name="cidade" class="form-control" placeholder="Ex: Cássia" required>
                        </div>
                        <div class="col-3">
                            <label for="modal-estado" class="form-label small fw-bold">Estado (UF)</label>
                            <input type="text" id="modal-estado" name="estado" class="form-control" placeholder="MG" maxlength="2" required>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm mt-2">Salvar Endereço</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
