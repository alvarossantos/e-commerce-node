<div class="container py-5">

    <% if (typeof erro !== 'undefined') { %>
        <% if (erro === 'vendas') { %>
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
                <i class="fas fa-exclamation-triangle fa-2x me-3" aria-hidden="true"></i>
                <div>
                    <strong>Ação Bloqueada:</strong> Este produto não pode ser excluído pois já foi vendido em pedido(s) realizado(s).
                    <br><small>Para manter a integridade das suas vendas, sugerimos <b>editar o produto e zerar o seu estoque</b>.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        <% } else if (erro === 'estoque') { %>
            <div class="alert alert-warning alert-dismissible fade show shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
                <i class="fas fa-box-open fa-2x me-3" aria-hidden="true"></i>
                <div>
                    <strong>Ação Bloqueada:</strong> Este produto não pode ser excluído pois ainda possui estoque disponível.
                    <br><small>Para excluir este produto, primeiro <b>zere o estoque</b> na edição do produto ou transfira o estoque para outro produto.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        <% } else if (erro === 'carrinho') { %>
            <div class="alert alert-info alert-dismissible fade show shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
                <i class="fas fa-shopping-cart fa-2x me-3" aria-hidden="true"></i>
                <div>
                    <strong>Ação Bloqueada:</strong> Este produto não pode ser excluído pois está no carrinho de compras de algum(ns) usuário(s).
                    <br><small>Aguarde os carrinhos expirarem ou <b>edite o produto</b> em vez de excluí-lo.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        <% } else if (erro === 'em_uso') { %>
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
                <i class="fas fa-exclamation-triangle fa-2x me-3" aria-hidden="true"></i>
                <div>
                    <strong>Ação Bloqueada:</strong> Este produto não pode ser excluído pois já faz parte do histórico de um pedido realizado.
                    <br><small>Para manter a integridade das suas vendas, sugerimos <b>editar o produto e zerar o seu estoque</b>.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        <% } else if (erro === 'nao_encontrado') { %>
            <div class="alert alert-secondary alert-dismissible fade show shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
                <i class="fas fa-info-circle fa-2x me-3" aria-hidden="true"></i>
                <div>
                    <strong>Produto não encontrado:</strong> O produto que você tentou excluir não existe ou já foi removido.
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        <% } %>
    <% } %>

    <% if (typeof sucesso !== 'undefined' && sucesso === 'excluido') { %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4 mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-check-circle fa-2x me-3" aria-hidden="true"></i>
            <div>
                <strong>Sucesso:</strong> Produto excluído permanentemente do sistema.
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    <% } %>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0 h3"><i class="fas fa-boxes me-2" aria-hidden="true"></i> Inventário de Produtos</h1>
        <div>
            <a href="/admin" class="btn btn-outline-secondary rounded-pill px-4 me-2">Voltar</a>
            <a href="/admin/produtos/novo" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fas fa-plus me-2" aria-hidden="true"></i> Novo Produto
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" aria-label="Lista de produtos">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" class="ps-4">Produto</th>
                        <th scope="col">Categoria</th>
                        <th scope="col">SKU</th>
                        <th scope="col">Preço</th>
                        <th scope="col" class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let p of produtos) { %>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="<%= p.url_imagem ? p.url_imagem : '/img/produtos/placeholder.png' %>" class="rounded border me-3" style="width: 45px; height: 45px; object-fit: contain;" alt="Imagem de <%= p.nome %>">
                                <span class="fw-bold"><%= p.nome %></span>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border"><%= p.categoria %></span></td>
                        <td class="text-muted small"><%= p.sku %></td>
                        <td class="fw-bold text-primary">R$ <%= parseFloat(p.preco).toFixed(2) %></td>
                        <td class="text-end pe-4">
                            <a href="/admin/produtos/<%= p.id %>" class="btn btn-sm btn-outline-info me-1" title="Ver Detalhes de <%= p.nome %>">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </a>
                            
                            <a href="/admin/produtos/<%= p.id %>/editar" class="btn btn-sm btn-outline-primary me-1" title="Editar <%= p.nome %>">
                                <i class="fas fa-edit" aria-hidden="true"></i>
                            </a>
                            
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#modalExcluir<%= p.id %>" title="Excluir <%= p.nome %>">
                                <i class="fas fa-trash" aria-hidden="true"></i>
                            </button>

                            <div class="modal fade" id="modalExcluir<%= p.id %>" tabindex="-1" aria-labelledby="modalLabel<%= p.id %>" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow rounded-4 text-start">
                                        <div class="modal-header border-bottom-0 pb-0 mt-2">
                                            <h5 class="modal-title fw-bold text-danger" id="modalLabel<%= p.id %>">
                                                <i class="fas fa-exclamation-circle me-2" aria-hidden="true"></i> Confirmar Exclusão
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                                        </div>
                                        <div class="modal-body py-4">
                                            <p class="mb-0 text-wrap text-break">Tem certeza que deseja excluir o produto <strong><%= p.nome %></strong> (SKU: <%= p.sku %>)?</p>
                                            <p class="text-muted small mt-2 mb-0">Esta ação não poderá ser desfeita. O sistema verificará vendas, estoque e carrinhos antes de permitir a exclusão.</p>
                                        </div>
                                        <div class="modal-footer border-top-0 pt-0 mb-2">
                                            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                                            <form action="/admin/produtos/<%= p.id %>?_method=DELETE" method="POST" class="m-0 p-0">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">Sim, Excluir</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <% } %>
                    </tbody>
            </table>
        </div>
    </div>
</div>
