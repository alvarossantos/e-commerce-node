<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NexStore — Sua loja online de hardware, periféricos e acessórios de tecnologia. Encontre os melhores preços!">
    <meta name="keywords" content="loja online, hardware, periféricos, tecnologia, computador, gamer, monitor">
    <meta property="og:title" content="NexStore — Loja de Tecnologia">
    <meta property="og:description" content="Os melhores preços em hardware, periféricos e acessórios.">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="pt_BR">
    <title>NexStore — Sua Loja de Tecnologia</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎮</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body x-data="nexstoreApp()" x-init="init()">

    <a href="#conteudo-principal" class="skip-link">Pular para o conteúdo principal</a>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm py-3" role="navigation" aria-label="Menu principal da loja">
        <div class="container">
            <a class="navbar-brand fs-4" href="/" aria-label="NexStore — Página Inicial"><i class="fas fa-gamepad text-primary me-2" aria-hidden="true"></i>Nex<span class="text-primary">Store</span></a>
            
            <!-- Botão hambúrguer animado -->
            <button class="ns-navbar-toggler" type="button" onclick="toggleMobileMenu()" aria-controls="navLoja" aria-expanded="false" aria-label="Abrir menu de navegação">
                <div class="ns-hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </button>

            <div class="navbar-collapse" id="navLoja">
                <form class="d-flex mx-auto w-50 my-2 my-lg-0" action="/" method="GET" role="search">
                    <div class="input-group">
                        <input class="form-control border-0 shadow-none" type="search" name="busca" placeholder="O que você está procurando?" aria-label="Buscar produtos" value="<%= typeof termoBusca !== 'undefined' ? termoBusca : '' %>">
                        <button class="btn btn-primary px-4" type="submit" aria-label="Buscar"><i class="fas fa-search" aria-hidden="true"></i></button>
                    </div>
                </form>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center" role="menubar">
    
                    <% if (usuarioLogado) { %>
                        <li class="nav-item dropdown me-lg-3" role="none">
                            <a class="nav-link dropdown-toggle fw-bold text-white d-flex align-items-center" href="#" id="menuUsuario" role="menuitem" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="<%= usuarioLogado.url_foto %>" class="rounded-circle me-2 bg-white" style="width: 32px; height: 32px; object-fit: cover; padding: 2px;" alt="Foto de perfil de <%= usuarioLogado.nome %>"> 
                                Olá, <%= usuarioLogado.nome.split(' ')[0] %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" role="menu">
                                
                                <% if (usuarioLogado.is_admin) { %>
                                    <li role="none">
                                        <a class="dropdown-item fw-bold text-primary py-2" href="/admin/dashboard" role="menuitem">
                                            <i class="fas fa-shield-alt me-2" aria-hidden="true"></i> Painel de Administração
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                <% } %>
                                
                                <li role="none"><a class="dropdown-item py-2" href="/pedidos/meus-pedidos" role="menuitem"><i class="fas fa-box me-2" aria-hidden="true"></i> Meus Pedidos</a></li>
                                <li role="none"><a class="dropdown-item py-2" href="/perfil" role="menuitem"><i class="fas fa-cog me-2" aria-hidden="true"></i> Minha Conta</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li role="none"><a class="dropdown-item py-2 text-danger fw-bold" href="/logout" role="menuitem"><i class="fas fa-sign-out-alt me-2" aria-hidden="true"></i> Sair da Conta</a></li>
                            </ul>
                        </li>
                        
                    <% } else { %>
                        <li class="nav-item me-lg-3" role="none">
                            <a class="nav-link fw-bold" href="/login" role="menuitem"><i class="fas fa-user-circle fs-5 me-1" aria-hidden="true"></i> Entrar / Cadastrar</a>
                        </li>
                    <% } %>

                    <li class="nav-item" role="none">
                        <a class="btn btn-outline-light position-relative rounded-pill px-3" href="/carrinho" role="menuitem" aria-label="Carrinho de compras">
                            <i class="fas fa-shopping-cart" aria-hidden="true"></i> Carrinho
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" aria-label="<%= typeof totalItensCarrinho !== 'undefined' ? totalItensCarrinho : '0' %> itens no carrinho" x-text="totalItens" x-show="totalItens > 0">
                                <%= typeof totalItensCarrinho !== 'undefined' ? totalItensCarrinho : '0' %>
                            </span>
                        </a>
                    </li>
                </ul>

            </div>
        </div>
    </nav>

    <main id="conteudo-principal" role="main">
        <%- body %>
    </main>

    <footer class="bg-dark text-white py-5 mt-5" role="contentinfo">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 mb-3">
                    <h5 class="footer-brand mb-3"><i class="fas fa-gamepad text-primary me-2" aria-hidden="true"></i>Nex<span class="text-primary">Store</span></h5>
                    <p class="text-white-50 small mb-0">Sua loja online de hardware, periféricos e acessórios de tecnologia.</p>
                </div>
                <div class="col-lg-4 mb-3">
                    <h6 class="fw-bold mb-3">Links Rápidos</h6>
                    <div class="footer-links d-flex flex-column gap-2">
                        <a href="/" class="small">Início</a>
                        <a href="/perfil" class="small">Minha Conta</a>
                        <a href="/pedidos/meus-pedidos" class="small">Meus Pedidos</a>
                        <a href="/carrinho" class="small">Carrinho</a>
                    </div>
                </div>
                <div class="col-lg-4 mb-3">
                    <h6 class="fw-bold mb-3">Contato</h6>
                    <p class="text-white-50 small mb-1"><i class="fas fa-envelope me-2" aria-hidden="true"></i>contato@nexstore.com.br</p>
                    <p class="text-white-50 small mb-0"><i class="fas fa-phone me-2" aria-hidden="true"></i>(31) 99999-0000</p>
                </div>
            </div>
            <hr class="border-secondary my-4">
            <div class="text-center">
                <p class="mb-0 text-white-50 small">&copy; 2026 NexStore. Todos os direitos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        (function () {
            var toggler = document.querySelector('.ns-navbar-toggler');
            var nav = document.getElementById('navLoja');

            function toggleMobileMenu() {
                var isOpen = nav.classList.toggle('show');
                toggler.classList.toggle('active', isOpen);
                toggler.setAttribute('aria-expanded', isOpen);
            }

            window.toggleMobileMenu = toggleMobileMenu;

            window.addEventListener('resize', function () {
                if (window.innerWidth >= 992) {
                    nav.classList.remove('show');
                    toggler.classList.remove('active');
                }
            });
        })();
    </script>
    <script>
        function nexstoreApp() {
            return {
                totalItens: parseInt('<%= typeof totalItensCarrinho !== "undefined" ? totalItensCarrinho : 0 %>') || 0,
                notificacao: null,
                notificacaoTipo: 'success',

                async init() {
                    await this.atualizarContadorCarrinho();
                },

                async atualizarContadorCarrinho() {
                    try {
                        const resp = await fetch('/api/carrinho');
                        const data = await resp.json();
                        if (data.sucesso) {
                            this.totalItens = data.totalItens;
                        }
                    } catch (e) {
                        // Silently fail — o fallback do EJS já cuida disso
                    }
                },

                async adicionarAoCarrinho(produtoId, quantidade = 1) {
                    try {
                        const resp = await fetch('/api/carrinho/adicionar', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ produto_id: produtoId, quantidade })
                        });
                        const data = await resp.json();

                        if (data.sucesso) {
                            this.totalItens = data.totalItens;
                            this.mostrarNotificacao(data.mensagem, 'success');
                        } else {
                            this.mostrarNotificacao(data.mensagem, 'danger');
                        }
                    } catch (e) {
                        this.mostrarNotificacao('Erro ao adicionar ao carrinho.', 'danger');
                    }
                },

                async removerDoCarrinho(produtoId) {
                    try {
                        const resp = await fetch('/api/carrinho/remover/' + produtoId, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        const data = await resp.json();

                        if (data.sucesso) {
                            this.totalItens = data.totalItens;
                            this.mostrarNotificacao(data.mensagem, 'success');
                            return data;
                        }
                    } catch (e) {
                        this.mostrarNotificacao('Erro ao remover item.', 'danger');
                    }
                    return null;
                },

                mostrarNotificacao(mensagem, tipo = 'success') {
                    this.notificacao = mensagem;
                    this.notificacaoTipo = tipo;
                    setTimeout(() => { this.notificacao = null; }, 3000);
                }
            };
        }
    </script>
    <!-- Toast Notificação Alpine.js -->
    <div x-show="notificacao" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 translate-y-2" :class="notificacaoTipo === 'success' ? 'ns-toast-success' : 'ns-toast-danger'" class="ns-toast position-fixed bottom-0 end-0 m-4 px-4 py-3 rounded-4 shadow-lg d-flex align-items-center gap-3" style="z-index: 9999; min-width: 300px;" role="alert" aria-live="polite">
        <i :class="notificacaoTipo === 'success' ? 'fas fa-check-circle text-success' : 'fas fa-exclamation-circle text-danger'" aria-hidden="true"></i>
        <span class="fw-bold small" x-text="notificacao"></span>
    </div>

</body>
</html>
