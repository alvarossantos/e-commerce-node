<div class="container py-5">
    
    <div class="d-flex flex-wrap gap-2 justify-content-center mb-5 scroll-categorias">
        <a href="/" class="cat-pill <%= categoriaAtiva === '' ? 'active' : '' %>">
            <i class="fas fa-th-large me-2"></i>Todas
        </a>
        <a href="/?categoria=Hardware" class="cat-pill <%= categoriaAtiva === 'Hardware' ? 'active' : '' %>">
            <i class="fas fa-microchip me-2"></i>Hardware
        </a>
        <a href="/?categoria=Periféricos" class="cat-pill <%= categoriaAtiva === 'Periféricos' ? 'active' : '' %>">
            <i class="fas fa-keyboard me-2"></i>Periféricos
        </a>
        <a href="/?categoria=Portáteis" class="cat-pill <%= categoriaAtiva === 'Portáteis' ? 'active' : '' %>">
            <i class="fas fa-laptop me-2"></i>Portáteis
        </a>
        <a href="/?categoria=Gamer" class="cat-pill <%= categoriaAtiva === 'Gamer' ? 'active' : '' %>">
            <i class="fas fa-headset me-2"></i>Gamer
        </a>
        <a href="/?categoria=Monitores" class="cat-pill <%= categoriaAtiva === 'Monitores' ? 'active' : '' %>">
            <i class="fas fa-desktop me-2"></i>Monitores
        </a>
    </div>

    <% if (termoBusca !== '') { %>
        <h4 class="fw-bold mb-4 text-secondary">Resultados para: <span class="text-primary">"<%= termoBusca %>"</span></h4>
    <% } else if (categoriaAtiva !== '') { %>
        <h4 class="fw-bold mb-4 text-secondary">Explorando: <span class="text-primary"><%= categoriaAtiva %></span></h4>
    <% } else { %>
        <h4 class="fw-bold mb-4 text-dark font-custom">Lançamentos e Destaques</h4>
    <% } %>

    <div class="row g-4">
        <% if (produtos.length > 0) { %>
            <% for(let p of produtos) { %>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 text-center text-decoration-none text-dark transition-hover">
                    <div class="p-4 d-flex align-items-center justify-content-center bg-white position-relative rounded-top-4" style="height: 200px;">
                        <img src="<%= p.url_imagem ? p.url_imagem : '/static/img/produtos/placeholder.png' %>" class="img-fluid" style="max-height: 100%; object-fit: contain;" alt="<%= p.nome %>">
                    </div>
                    <div class="card-body d-flex flex-column border-top bg-white rounded-bottom-4">
                        <span class="badge bg-light text-secondary border mb-2 align-self-start py-1.5 px-2.5 rounded-pill small"><%= p.categoria %></span>
                        <h6 class="card-title fw-bold text-start text-dark mb-3 text-truncate-2" style="min-height: 44px; font-size: 0.95rem; line-height: 1.4;"><%= p.nome %></h6>
                        
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-primary mb-0" style="letter-spacing: -0.5px;">R$ <%= parseFloat(p.preco).toFixed(2) %></h5>
                            <a href="/produtos/<%= p.id %>" class="btn-arrow-details">
                                <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                <h4 class="fw-bold text-muted">Nenhum produto encontrado.</h4>
                <p class="text-secondary">Tente buscar por outro termo ou mude de categoria.</p>
                <a href="/" class="btn btn-primary rounded-pill px-4 mt-2">Ver tudo</a>
            </div>
        <% } %>
    </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&display=swap');
    
    .font-custom { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; }
    
    .cat-pill {
        display: inline-flex;
        align-items: center;
        padding: 10px 22px;
        background-color: #ebedf0;
        color: #4a5568;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 50px;
        text-decoration: none;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
    }
    .cat-pill i { color: #718096; transition: color 0.25s ease; }
    .cat-pill:hover { background-color: #e2e8f0; color: #1a202c; transform: translateY(-1px); }
    .cat-pill.active { background: linear-gradient(135deg, #0d6efd, #0a58ca); color: #ffffff; box-shadow: 0 4px 12px rgba(13, 110, 253, 0.25); }
    .cat-pill.active i { color: #ffffff; }

    .transition-hover { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .transition-hover:hover { transform: translateY(-6px); box-shadow: 0 12px 20px rgba(0,0,0,0.08) !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .btn-arrow-details {
        width: 36px;
        height: 36px;
        background-color: #f1f3f5;
        color: #212529;
        border-radius: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .btn-arrow-details:hover { background-color: #212529; color: #ffffff; }
</style>