<div class="container py-5">
    
    <div class="d-flex flex-wrap gap-2 justify-content-center mb-5 scroll-categorias" role="navigation" aria-label="Categorias de produtos">
        <a href="/" class="cat-pill <%= categoriaAtiva === '' ? 'active' : '' %>" aria-label="Ver todas as categorias">
            <i class="fas fa-th-large me-2" aria-hidden="true"></i>Todas
        </a>
        <a href="/?categoria=Hardware" class="cat-pill <%= categoriaAtiva === 'Hardware' ? 'active' : '' %>" aria-label="Categoria Hardware">
            <i class="fas fa-microchip me-2" aria-hidden="true"></i>Hardware
        </a>
        <a href="/?categoria=Periféricos" class="cat-pill <%= categoriaAtiva === 'Periféricos' ? 'active' : '' %>" aria-label="Categoria Periféricos">
            <i class="fas fa-keyboard me-2" aria-hidden="true"></i>Periféricos
        </a>
        <a href="/?categoria=Portáteis" class="cat-pill <%= categoriaAtiva === 'Portáteis' ? 'active' : '' %>" aria-label="Categoria Portáteis">
            <i class="fas fa-laptop me-2" aria-hidden="true"></i>Portáteis
        </a>
        <a href="/?categoria=Gamer" class="cat-pill <%= categoriaAtiva === 'Gamer' ? 'active' : '' %>" aria-label="Categoria Gamer">
            <i class="fas fa-headset me-2" aria-hidden="true"></i>Gamer
        </a>
        <a href="/?categoria=Monitores" class="cat-pill <%= categoriaAtiva === 'Monitores' ? 'active' : '' %>" aria-label="Categoria Monitores">
            <i class="fas fa-desktop me-2" aria-hidden="true"></i>Monitores
        </a>
    </div>

    <% if (termoBusca !== '') { %>
        <h1 class="fw-bold mb-4 text-secondary h4">Resultados para: <span class="text-primary">"<%= termoBusca %>"</span></h1>
    <% } else if (categoriaAtiva !== '') { %>
        <h1 class="fw-bold mb-4 text-secondary h4">Explorando: <span class="text-primary"><%= categoriaAtiva %></span></h1>
    <% } else { %>
        <h1 class="fw-bold mb-4 text-dark font-custom h4">Lançamentos e Destaques</h1>
    <% } %>

    <div class="row g-4">
        <% if (produtos.length > 0) { %>
            <% for(let p of produtos) { %>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <article class="card h-100 border-0 shadow-sm rounded-4 text-center text-decoration-none text-dark transition-hover">
                    <div class="p-4 d-flex align-items-center justify-content-center bg-white position-relative rounded-top-4" style="height: 200px;">
                        <img src="<%= p.url_imagem ? p.url_imagem : '/img/produtos/placeholder.png' %>" class="img-fluid" style="max-height: 100%; object-fit: contain;" alt="Imagem de <%= p.nome %>">
                    </div>
                    <div class="card-body d-flex flex-column border-top bg-white rounded-bottom-4">
                        <span class="badge bg-light text-secondary border mb-2 align-self-start py-1.5 px-2.5 rounded-pill small"><%= p.categoria %></span>
                        <h2 class="card-title fw-bold text-start text-dark mb-3 text-truncate-2" style="min-height: 44px; font-size: 0.95rem; line-height: 1.4;"><%= p.nome %></h2>
                        
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <p class="fw-bold text-primary mb-0 h5" style="letter-spacing: -0.5px;">R$ <%= parseFloat(p.preco).toFixed(2) %></p>
                            <a href="/produtos/<%= p.id %>" class="btn-arrow-details" aria-label="Ver detalhes de <%= p.nome %>">
                                <i class="fas fa-arrow-right" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>
                </article>
            </div>
            <% } %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <i class="fas fa-search fa-3x text-muted mb-3" aria-hidden="true"></i>
                <h2 class="fw-bold text-muted h5">Nenhum produto encontrado.</h2>
                <p class="text-secondary">Tente buscar por outro termo ou mude de categoria.</p>
                <a href="/" class="btn btn-primary rounded-pill px-4 mt-2 fw-bold">Ver tudo</a>
            </div>
        <% } %>
    </div>
</div>
