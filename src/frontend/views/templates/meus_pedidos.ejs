<div class="container py-5 font-custom">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0 h3"><i class="fas fa-box-open text-primary me-2" aria-hidden="true"></i>Meus Pedidos</h1>
            <p class="text-muted mb-0">Acompanhe o histórico e o estado das suas compras.</p>
        </div>
        <a href="/" class="btn btn-outline-secondary rounded-pill px-4">Continuar Comprando</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <% if (pedidos && pedidos.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" aria-label="Histórico de pedidos">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th scope="col" class="ps-4 py-3">Nº do Pedido</th>
                            <th scope="col">Data da Compra</th>
                            <th scope="col">Total Pago</th>
                            <th scope="col">Estado</th>
                            <th scope="col" class="text-end pe-4">Recibo</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let ped of pedidos) { %>
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#<%= ped.id %></td>
                                <td><%= new Date(ped.data_criacao).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %></td>
                                <td class="fw-bold text-success">R$ <%= parseFloat(ped.valor_total).toFixed(2) %></td>
                                <td>
                                    <% if (ped.status === 'pendente') { %>
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="fas fa-clock me-1" aria-hidden="true"></i> Pendente</span>
                                    <% } else if (ped.status === 'pago') { %>
                                        <span class="badge bg-primary rounded-pill px-3 py-2"><i class="fas fa-check me-1" aria-hidden="true"></i> Pago</span>
                                    <% } else if (ped.status === 'enviado') { %>
                                        <span class="badge bg-info text-white rounded-pill px-3 py-2"><i class="fas fa-truck me-1" aria-hidden="true"></i> Enviado</span>
                                    <% } else if (ped.status === 'entregue') { %>
                                        <span class="badge bg-dark rounded-pill px-3 py-2"><i class="fas fa-box-open me-1" aria-hidden="true"></i> Entregue</span>
                                    <% } else { %>
                                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fas fa-times me-1" aria-hidden="true"></i> Cancelado</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/pedidos/sucesso/<%= ped.id %>?metodo=pix" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fas fa-file-invoice me-1" aria-hidden="true"></i> Detalhes
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <i class="fas fa-shopping-bag fa-4x text-muted mb-3 opacity-50" aria-hidden="true"></i>
                <h2 class="fw-bold text-dark h5">Ainda não fez nenhuma compra</h2>
                <p class="text-muted">Parece que o seu histórico está vazio. Que tal dar uma olhadela nas novidades?</p>
                <a href="/" class="btn btn-primary rounded-pill px-4 mt-2 fw-bold">Explorar Loja</a>
            </div>
        <% } %>
    </div>
</div>
