<div class="container py-5 font-custom">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                
                <div class="bg-success text-white p-4 text-center">
                    <i class="fas fa-check-circle fa-4x mb-3"></i>
                    <h2 class="fw-bold">Pagamento Aprovado!</h2>
                    <p class="mb-0">A sua transação simulada foi concluída com sucesso.</p>
                </div>
                
                <div class="card-body p-4 bg-white">
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <h6 class="text-muted fw-bold text-uppercase mb-2">Número do Pedido</h6>
                            <h4 class="fw-bold text-dark">#<%= pedido.id %></h4>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <h6 class="text-muted fw-bold text-uppercase mb-2">Data da Compra</h6>
                            <h5 class="fw-bold text-dark"><%= new Date(pedido.data_criacao).toLocaleDateString('pt-BR') %></h5>
                        </div>
                    </div>

                    <div class="alert bg-light border rounded-3 mb-4">
                        <h6 class="fw-bold mb-2"><i class="fas fa-wallet text-primary me-2"></i> Forma de Pagamento</h6>
                        <% if (metodoPagamento === 'pix') { %>
                            <p class="mb-0 text-success fw-bold"><i class="fab fa-pix me-1"></i> Transação PIX (Liquidado)</p>
                        <% } else { %>
                            <p class="mb-0 text-primary fw-bold"><i class="fas fa-credit-card me-1"></i> Cartão de Crédito (Aprovado)</p>
                        <% } %>
                    </div>

                    <h6 class="fw-bold border-bottom pb-2 mb-3">Itens Comprados</h6>
                    <div class="table-responsive mb-4">
                        <table class="table align-middle">
                            <tbody>
                                <% for(let item of itens) { %>
                                    <tr>
                                        <td style="width: 60px;">
                                            <img src="<%= item.imagem || '/img/produtos/placeholder.png' %>" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;">
                                        </td>
                                        <td>
                                            <h6 class="mb-0 fw-bold"><%= item.nome %></h6>
                                            <small class="text-muted"><%= item.quantidade %>x R$ <%= parseFloat(item.preco_unitario).toFixed(2) %></small>
                                        </td>
                                        <td class="text-end fw-bold text-dark">
                                            R$ <%= (parseFloat(item.preco_unitario) * item.quantidade).toFixed(2) %>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                            <tfoot class="bg-light border-top">
                                <tr>
                                    <td colspan="2" class="text-end fw-bold text-muted py-3">Total Pago:</td>
                                    <td class="text-end fw-bold text-success fs-5 py-3">R$ <%= parseFloat(pedido.valor_total).toFixed(2) %></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="p-3 bg-light rounded-3 border">
                        <h6 class="fw-bold mb-2"><i class="fas fa-map-marker-alt text-danger me-2"></i> Entregar em:</h6>
                        <p class="mb-0 small text-secondary">
                            <%= pedido.logradouro %>, <%= pedido.numero %> <% if (pedido.complemento) { %> - <%= pedido.complemento %> <% } %><br>
                            <%= pedido.bairro %> - <%= pedido.cidade %>/<%= pedido.estado %> | CEP: <%= pedido.cep %>
                        </p>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <a href="/pedidos/meus-pedidos" class="btn btn-outline-primary rounded-pill px-4 me-2 fw-bold shadow-sm">Ver Meus Pedidos</a>
                <a href="/" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Continuar Comprando</a>
            </div>
        </div>
    </div>
</div>