<div class="container py-5">

    <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <div class="alert ns-alert ns-alert-success mb-4" role="alert">
            <div class="ns-alert-icon"><i class="fas fa-check" aria-hidden="true"></i></div>
            <div class="ns-alert-content">
                <div class="ns-alert-title">Sucesso</div>
                <p class="ns-alert-text"><%= sucesso %></p>
            </div>
            <button type="button" class="ns-alert-close" data-bs-dismiss="alert" aria-label="Fechar"><i class="fas fa-times"></i></button>
        </div>
    <% } %>

    <% if (typeof erro !== 'undefined' && erro) { %>
        <div class="alert ns-alert ns-alert-danger mb-4" role="alert">
            <div class="ns-alert-icon"><i class="fas fa-circle-exclamation" aria-hidden="true"></i></div>
            <div class="ns-alert-content">
                <div class="ns-alert-title">Erro</div>
                <p class="ns-alert-text"><%= erro %></p>
            </div>
            <button type="button" class="ns-alert-close" data-bs-dismiss="alert" aria-label="Fechar"><i class="fas fa-times"></i></button>
        </div>
    <% } %>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0 h3"><i class="fas fa-boxes text-dark me-2" aria-hidden="true"></i> Gestão de Pedidos</h1>
            <p class="text-muted mb-0">Controlo de vendas e envios da loja.</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fas fa-arrow-left me-2" aria-hidden="true"></i> Voltar ao Painel
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap" aria-label="Lista de pedidos">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" class="ps-4 py-3">ID Pedido</th>
                        <th scope="col">Cliente</th>
                        <th scope="col">Data</th>
                        <th scope="col">Valor Total</th>
                        <th scope="col">Estado Atual</th>
                        <th scope="col" class="text-end pe-4">Ação</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (pedidos && pedidos.length > 0) { %>
                        <% for(let ped of pedidos) { %>
                        <tr>
                            <td class="ps-4 fw-bold">#<%= ped.id %></td>
                            <td><%= ped.nome_usuario %></td>
                            <td><%= new Date(ped.data_criacao).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' }) %></td>
                            <td class="fw-bold text-primary">R$ <%= parseFloat(ped.valor_total).toFixed(2) %></td>
                            
                            <td>
                                <% if (ped.status === 'pendente') { %>
                                    <span class="badge bg-warning text-dark px-2 py-1 rounded-pill"><i class="fas fa-clock me-1" aria-hidden="true"></i> Pendente</span>
                                <% } else if (ped.status === 'em_analise') { %>
                                    <span class="badge bg-info text-white px-2 py-1 rounded-pill"><i class="fas fa-search me-1" aria-hidden="true"></i> Em Análise</span>
                                <% } else if (ped.status === 'pago') { %>
                                    <span class="badge bg-success px-2 py-1 rounded-pill"><i class="fas fa-check me-1" aria-hidden="true"></i> Pago</span>
                                <% } else if (ped.status === 'enviado') { %>
                                    <span class="badge bg-primary px-2 py-1 rounded-pill"><i class="fas fa-truck me-1" aria-hidden="true"></i> Enviado</span>
                                <% } else if (ped.status === 'entregue') { %>
                                    <span class="badge bg-dark px-2 py-1 rounded-pill"><i class="fas fa-home me-1" aria-hidden="true"></i> Entregue</span>
                                <% } else { %>
                                    <span class="badge bg-danger px-2 py-1 rounded-pill">Cancelado</span>
                                <% } %>
                            </td>

                            <td class="text-end pe-4">
                                <form action="/pedidos/<%= ped.id %>/status?_method=PATCH" method="POST" class="d-flex justify-content-end gap-2">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <label for="status-<%= ped.id %>" class="visually-hidden">Status do pedido #<%= ped.id %></label>
                                    <select id="status-<%= ped.id %>" name="status" class="form-select form-select-sm w-auto shadow-none border-secondary">
                                        <option value="pendente" <%= ped.status === 'pendente' ? 'selected' : '' %>>Pendente</option>
                                        <option value="em_analise" <%= ped.status === 'em_analise' ? 'selected' : '' %>>Em Análise</option>
                                        <option value="pago" <%= ped.status === 'pago' ? 'selected' : '' %>>Aprovar Pagamento</option>
                                        <option value="enviado" <%= ped.status === 'enviado' ? 'selected' : '' %>>Marcar como Enviado</option>
                                        <option value="entregue" <%= ped.status === 'entregue' ? 'selected' : '' %>>Confirmar Entrega</option>
                                        <option value="cancelado" <%= ped.status === 'cancelado' ? 'selected' : '' %>>Cancelar Pedido</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-dark px-3 fw-bold rounded-pill">Atualizar</button>
                                </form>
                            </td>
                        </tr>
                        <% } %>
                    <% } else { %>
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fas fa-box-open fa-3x mb-3" aria-hidden="true"></i><br>
                            Nenhum pedido realizado até o momento.
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
