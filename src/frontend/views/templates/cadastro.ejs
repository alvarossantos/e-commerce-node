<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow rounded-4 p-4 mt-2">
                <div class="text-center mb-4">
                    <h3 class="fw-bold">Crie a sua conta</h3>
                    <p class="text-muted small">Junte-se à Álvaro Store e aproveite as nossas ofertas.</p>
                </div>

                <% if (typeof erro !== 'undefined' && erro) { %>
                    <div class="alert alert-danger small py-2 rounded-3 text-center"><%= erro %></div>
                <% } %>

                <form action="/cadastro" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Nome Completo</label>
                        <input type="text" name="nome" class="form-control rounded-pill px-4" required placeholder="Nome Completo">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">E-mail</label>
                        <input type="email" name="email" class="form-control rounded-pill px-4" required placeholder="seu@email.com">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">CPF (apenas números)</label>
                        <input type="text" name="cpf" class="form-control rounded-pill px-4" required placeholder="12345678901" pattern="\d{11}" title="Digite os 11 dígitos do CPF, apenas números.">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Data de Nascimento</label>
                        <input type="date" name="data_nascimento" class="form-control rounded-pill px-4" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small">Crie uma Senha</label>
                        <input type="password" name="senha" class="form-control rounded-pill px-4" required placeholder="Mínimo de 6 caracteres">
                    </div>
                    <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold py-2 shadow-sm">Criar Conta</button>
                </form>
                
                <div class="text-center mt-4 pt-3 border-top">
                    <span class="text-muted small">Já é cliente?</span>
                    <a href="/login" class="text-decoration-none fw-bold ms-1">Fazer Login</a>
                </div>
            </div>
        </div>
    </div>
</div>