<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>NexStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .navbar-brand { font-weight: 800; letter-spacing: -1px; }
        .card-product:hover { transform: translateY(-5px); transition: 0.3s; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛒 NexStore</a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navConteudo">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navConteudo">

                <form action="/" method="GET" class="d-flex border rounded p-1 bg-white my-3 my-lg-0 ms-lg-4 flex-grow-1" style="max-width: 600px;">
                    <input class="form-control border-0 shadow-none" type="search" name="busca" placeholder="O que você procura?" value="<%= typeof termoBusca !== 'undefined' ? termoBusca : '' %>">
                    <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
                </form>

                <div class="ms-auto d-flex align-items-center gap-3">
                    <% if (typeof usuarioLogado !== 'undefined' && usuarioLogado) { %>
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center text-white" href="#" role="button" data-bs-toggle="dropdown">
                                <img src="<%= usuarioLogado.url_foto || '/img/usuarios/default.png' %>" class="rounded-circle me-2" style="width: 35px; height: 35px; object-fit: cover; border: 2px solid #fff;">
                                <span>Olá, <%= usuarioLogado.nome.split(' ')[0] %></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <% if (usuarioLogado.is_admin) { %>
                                    <li><a class="dropdown-item fw-bold text-primary" href="/admin"><i class="fas fa-shield-alt me-2"></i> Painel Admin</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                <% } %>

                                <li><a class="dropdown-item" href="/perfil"><i class="fas fa-user-circle me-2"></i> Perfil</a></li>
                                <li><a class="dropdown-item" href="/pedidos/meus-pedidos"><i class="fas fa-box me-2"></i> Pedidos</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i> Sair</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/login" class="btn btn-link text-white text-decoration-none fw-bold">Entrar</a>
                        <a href="/cadastro" class="btn btn-primary rounded-pill px-4 fw-bold">Criar Conta</a>
                    <% } %>

                    <a href="/carrinho" class="btn btn-link text-white position-relative p-2">
                        <i class="fas fa-shopping-cart fa-lg"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                            <%= typeof totalItensCarrinho !== 'undefined' ? totalItensCarrinho : '0' %>
                        </span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <% if (typeof erro !== 'undefined' && erro) { %>
            <div class="alert alert-danger shadow-sm"><i class="fas fa-exclamation-triangle me-2"></i><%= erro %></div>
        <% } %>
        <% if (typeof sucesso !== 'undefined' && sucesso) { %>
            <div class="alert alert-success shadow-sm"><i class="fas fa-check-circle me-2"></i><%= sucesso %></div>
        <% } %>

        <%- body %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>