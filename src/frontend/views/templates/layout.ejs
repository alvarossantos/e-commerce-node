<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NexStore — Painel de Administração. Gestão de produtos, pedidos e usuários.">
    <meta name="robots" content="noindex, nofollow">
    <title>NexStore | Painel Admin</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

    <a href="#conteudo-principal" class="skip-link">Pular para o conteúdo principal</a>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm py-3" role="navigation" aria-label="Menu do administrador">
        <div class="container">

            <a class="navbar-brand fs-4" href="/admin/dashboard" aria-label="NexStore Admin — Início">
                <i class="fas fa-shield-alt text-primary me-2" aria-hidden="true"></i>Nex<span class="text-primary">Store</span> <span class="fs-6 text-muted ms-1">Admin</span>
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navAdmin" aria-controls="navAdmin" aria-expanded="false" aria-label="Abrir menu de navegação">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navAdmin">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-3" role="menubar">
                    <li class="nav-item" role="none">
                        <a class="nav-link fw-bold" href="/admin/dashboard" role="menuitem"><i class="fas fa-chart-pie me-1" aria-hidden="true"></i> Dashboard</a>
                    </li>
                    <li class="nav-item" role="none">
                        <a class="nav-link fw-bold" href="/admin/produtos" role="menuitem"><i class="fas fa-box-open me-1" aria-hidden="true"></i> Produtos</a>
                    </li>
                    <li class="nav-item" role="none">
                        <a class="nav-link fw-bold" href="/admin/pedidos" role="menuitem"><i class="fas fa-shipping-fast me-1" aria-hidden="true"></i> Pedidos</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center" role="menubar">
                    <% if (typeof usuarioLogado !== 'undefined' && usuarioLogado) { %>
                        <li class="nav-item dropdown" role="none">
                            <a class="nav-link dropdown-toggle fw-bold text-white d-flex align-items-center" href="#" id="adminMenu" role="menuitem" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="<%= usuarioLogado.url_foto || '/img/usuarios/default.png' %>" class="rounded-circle me-2 bg-white" style="width: 32px; height: 32px; object-fit: cover; padding: 2px;" alt="Foto de perfil de <%= usuarioLogado.nome %>">
                                Olá, <%= usuarioLogado.nome.split(' ')[0] %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2 rounded-3" role="menu">
                                <li role="none"><a class="dropdown-item py-2 fw-bold text-primary" href="/" role="menuitem"><i class="fas fa-store me-2" aria-hidden="true"></i> Ir para a Loja</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li role="none"><a class="dropdown-item py-2 text-danger fw-bold" href="/logout" role="menuitem"><i class="fas fa-sign-out-alt me-2" aria-hidden="true"></i> Sair do Painel</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item" role="none">
                            <a href="/login" class="btn btn-outline-light rounded-pill px-4 fw-bold" role="menuitem">Entrar</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main id="conteudo-principal" class="container mt-4 mb-5" role="main">
        <% if (typeof erro !== 'undefined' && erro) { %>
            <div class="alert alert-danger shadow-sm rounded-3 border-0" role="alert"><i class="fas fa-exclamation-triangle me-2" aria-hidden="true"></i><%= erro %></div>
        <% } %>
        <% if (typeof sucesso !== 'undefined' && sucesso) { %>
            <div class="alert alert-success shadow-sm rounded-3 border-0" role="alert"><i class="fas fa-check-circle me-2" aria-hidden="true"></i><%= sucesso %></div>
        <% } %>

        <%- body %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
